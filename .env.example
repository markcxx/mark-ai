# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_BASE_URL=""

# Comma-separated model ids enabled in the model selector.
# Only configured model ids are returned by /api/models and shown in the UI.
GEMINI_MODELS="gemini-2.5-flash,gemini-2.5-pro"

OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODELS=""

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODELS=""

# Local SQLite persistence for conversations.
# The app uses Node's built-in sqlite module. Override this path if needed.
MARKAI_SQLITE_PATH=".data/markai.sqlite"

# Optional conversation title model in provider/modelId format.
# The provider/model must already be configured above, for example:
# MARKAI_CONVERSATION_TITLE_MODEL="deepseek/deepseek-chat"
MARKAI_CONVERSATION_TITLE_MODEL=""

# Optional OpenAI-compatible custom providers.
# Example:
# AI_PROVIDERS="openrouter,moonshot"
# OPENROUTER_API_KEY=""
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_MODELS="openai/gpt-4.1,anthropic/claude-sonnet-4"
# MARKAIDEEPSEEK_API_KEY=""
# MARKAIDEEPSEEK_API_URL="https://deepseekapi.markqq.com/v1"
# MARKAIDEEPSEEK_MODELS="deepseek-chat,deepseek-reasoner,deepseek-reasoner-search"
# MOONSHOT_API_KEY=""
# MOONSHOT_BASE_URL="https://api.moonshot.cn/v1"
# MOONSHOT_MODELS="moonshot-v1-8k,kimi-k2-0711-preview"
AI_PROVIDERS=""

# Optional per-model config. Use apiKeyEnv/baseUrlEnv to avoid putting secrets in this JSON.
# AI_MODEL_CONFIGS='[{"provider":"openrouter","id":"openai/gpt-4.1","runtime":"openai-compatible","apiKeyEnv":"OPENROUTER_API_KEY","baseUrlEnv":"OPENROUTER_BASE_URL"}]'
AI_MODEL_CONFIGS=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
