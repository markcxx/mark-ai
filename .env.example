# ============================================================
#  MarkAI — 环境变量配置
# ============================================================
#  复制此文件为 .env.local 并填入你的 API Key。
#  Base URL 已内置默认值，仅在需要自定义时才填写。
#  MODELS 填逗号分隔的模型 ID，留空则该平台不启用。
# ============================================================

# -------------------- 内置平台 --------------------

# Google Gemini
GEMINI_API_KEY=""
GEMINI_MODELS="gemini-2.5-flash,gemini-2.5-pro"
# GEMINI_BASE_URL=""

# OpenAI  (默认 https://api.openai.com/v1)
OPENAI_API_KEY=""
OPENAI_MODELS=""
# OPENAI_BASE_URL="https://api.openai.com/v1"

# DeepSeek  (默认 https://api.deepseek.com)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODELS=""
# DEEPSEEK_BASE_URL="https://api.deepseek.com"

# HuggingFace  (默认 https://api-inference.huggingface.co/v1)
HUGGINGFACE_API_KEY=""
HUGGINGFACE_MODELS=""
# HUGGINGFACE_BASE_URL="https://api-inference.huggingface.co/v1"

# 阿里云百炼  (默认 https://dashscope.aliyuncs.com/compatible-mode/v1)
BAILIAN_API_KEY=""
BAILIAN_MODELS=""
# BAILIAN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 无问芯穹  (默认 https://cloud.infini-ai.com/maas/v1)
INFINIAI_API_KEY=""
INFINIAI_MODELS=""
# INFINIAI_BASE_URL="https://cloud.infini-ai.com/maas/v1"

# -------------------- 自定义平台 --------------------

# 逗号分隔的自定义供应商名称，每个需配置对应的 API_KEY / BASE_URL / MODELS。
# 以 MARK 开头的供应商（如 MARKGPT、MARKAIDS）会统一归属 MarkAI，
# 相同模型 ID 会随机选择一个渠道发送请求。
#
# 示例:
# AI_PROVIDERS="markgpt,markaids,openrouter,moonshot"
#
# MARKGPT_API_KEY=""
# MARKGPT_BASE_URL="https://your-proxy.example.com/v1"
# MARKGPT_MODELS="gpt-4o,claude-sonnet-4"
#
# MARKAIDS_API_KEY=""
# MARKAIDS_BASE_URL="https://another-proxy.example.com/v1"
# MARKAIDS_MODELS="gpt-4o,deepseek-chat"
#
# OPENROUTER_API_KEY=""
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_MODELS="openai/gpt-4.1,anthropic/claude-sonnet-4"
#
# MOONSHOT_API_KEY=""
# MOONSHOT_BASE_URL="https://api.moonshot.cn/v1"
# MOONSHOT_MODELS="moonshot-v1-8k,kimi-k2-0711-preview"
AI_PROVIDERS=""

# 可选：JSON 格式的逐模型配置，支持 apiKeyEnv / baseUrlEnv 引用环境变量。
# AI_MODEL_CONFIGS='[{"provider":"openrouter","id":"openai/gpt-4.1","runtime":"openai-compatible","apiKeyEnv":"OPENROUTER_API_KEY","baseUrlEnv":"OPENROUTER_BASE_URL"}]'
AI_MODEL_CONFIGS=""

# -------------------- 数据库 --------------------

# 存储模式：
#   - 设置 MARKAI_SQLITE_PATH → 本地 SQLite 模式（无需登录）
#   - 设置 DATABASE_URL 且不设 MARKAI_SQLITE_PATH → 云端 PostgreSQL 模式（需要登录）
MARKAI_SQLITE_PATH=".data/markai.sqlite"
# 本地模式附件目录；留空时使用 SQLite 文件同级的 files/ 目录。
# MARKAI_LOCAL_FILES_DIR=".data/files"
# 单文件限制默认 20 MB；本地模式不限制文件总数和总容量。
# MARKAI_MAX_FILE_BYTES="20971520"
# MARKAI_MAX_AVATAR_BYTES="2097152"
# MARKAI_MAX_FILE_COUNT="50"
# MARKAI_MAX_STORAGE_BYTES="209715200"
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# -------------------- 对象存储（云端模式） --------------------

# 云端文件与头像使用 Cloudflare R2。私有桶保存聊天附件，公开桶保存用户头像。
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_PRIVATE_BUCKET=""
# R2_PUBLIC_BUCKET=""
# R2_PUBLIC_BASE_URL="https://files.example.com"
# R2_ENDPOINT=""
# R2_REGION="auto"
# R2_PRESIGNED_URL_EXPIRES="600"

# -------------------- 认证（云端模式必填） --------------------

# Better Auth 密钥（生产环境必须设置，可用 openssl rand -base64 32 生成）
# AUTH_SECRET=""
# 服务端认证基准地址（生产环境推荐设置，运行时生效，不会固化进构建产物）
# APP_URL="https://ai.example.com"

# 注册策略：open = 开放注册，waitlist = 等候名单，closed = 完全关闭
AUTH_REGISTRATION_MODE=open
# 初始管理员邮箱，多个邮箱使用逗号分隔；等候名单新申请默认通知这些管理员
AUTH_ADMIN_EMAILS=
# 等候名单邀请链接有效期（小时）
WAITLIST_INVITE_TTL_HOURS=72

# 用户自定义模型提供商 API Key 的加密密钥（推荐独立于 AUTH_SECRET）
# 生产环境设置后不要随意更换，否则已保存的 API Key 将无法解密。
# 可用 openssl rand -base64 32 生成；未设置时会回退使用 AUTH_SECRET。
# CREDENTIAL_ENCRYPTION_KEY=""

# 启用的 SSO 提供商（逗号分隔：google,github）
# AUTH_SSO_PROVIDERS=""

# 是否额外发送 Better Auth 邮箱验证链接；验证码注册和候补邀请本身已完成邮箱验证
EMAIL_VERIFICATION_ENABLED=false

# Google OAuth
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# GitHub OAuth
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# -------------------- 邮件服务（SMTP） --------------------

# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""

# -------------------- 功能配置 --------------------

# 自动生成会话标题的模型（格式：provider/modelId，需已配置）
# 示例: MARKAI_CONVERSATION_TITLE_MODEL="deepseek/deepseek-chat"
MARKAI_CONVERSATION_TITLE_MODEL=""

# 联网搜索 & 网页阅读
# FIRECRAWL_API_KEY 支持逗号分隔多个 Key；网页阅读优先 Firecrawl，回退 Tavily。
FIRECRAWL_API_KEY=""
TAVILY_API_KEY=""
