# PostgreSQL enables cloud mode. Do not set MARKAI_SQLITE_PATH in cloud mode.
DATABASE_URL=

# Authentication and the public application URL.
AUTH_SECRET=
APP_URL=https://ai.example.com
NEXT_PUBLIC_APP_URL=https://ai.example.com

# Cloudflare R2 stores attachments and avatars in cloud mode.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_REGION=auto
R2_PUBLIC_BUCKET=
R2_PRIVATE_BUCKET=
R2_PUBLIC_BASE_URL=

# Configure at least one model provider.
GEMINI_API_KEY=
GEMINI_MODELS=
OPENAI_API_KEY=
OPENAI_MODELS=
DEEPSEEK_API_KEY=
DEEPSEEK_MODELS=

AI_PROVIDERS=
AI_MODEL_CONFIGS=

MARKAI_CONVERSATION_TITLE_MODEL=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
